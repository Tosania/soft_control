      <site name="ring2_north"  pos="0 0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring2_south"  pos="0 -0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring2_east"  pos="0.08 0.0 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring2_west"  pos="-0.08 0 0" size="0.003" rgba="1 0 0 1"/>
      <site name="ring2_first" pos="0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring2_second" pos="-0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring2_third" pos="-0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring2_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
    </body>

    <body name="ring_3_body" pos="0 0 1.0">
    <joint type="free"/>
      <geom name="ring_3" type="cylinder" size="0.1 0.004"
