  <equality>
    <weld body1="rodB_first" body2="rod_base" solref="0.0001 1" solimp="0.999 0.999 0.01"/>
    <weld body1="rodB_8" body2="ring_1_body" solref="0.0001 1" solimp="0.999 0.999 0.01"/>
