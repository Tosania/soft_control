      <site name="ring4_north"  pos="0 0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring4_south"  pos="0 -0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring4_east"  pos="0.08 0.0 0.00" size="0.003" rgba="1 0 0 1"/>
