  <actuator>
  <position name="act_tendon_north_1" tendon="tendon_north_1" kp="{kp_val}" ctrllimited="true" ctrlrange="0 1"/>
  <position name="act_tendon_south_1" tendon="tendon_south_1" kp="{kp_val}" ctrllimited="true" ctrlrange="0 1"/>
