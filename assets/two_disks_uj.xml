      <site name="ring10_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="rod_tip" pos="0 0 0.00" size="0.002" rgba="1 1 0 1"/>
    </body>
  </worldbody>


  <tendon>

  <spatial name="tendon_north_1" width="0.002" rgba="0.1 0.1 0.9 1">
    <site site="base_north"/>
    <site site="ring1_north"/>
    <site site="ring2_north"/>
    <site site="ring3_north"/>
    <site site="ring4_north"/>
    <site site="ring5_north"/>
  </spatial>

  <spatial name="tendon_south_1" width="0.002" rgba="0.1 0.1 0.9 1">
    <site site="base_south"/>
    <site site="ring1_south"/>
    <site site="ring2_south"/>
    <site site="ring3_south"/>
    <site site="ring4_south"/>
    <site site="ring5_south"/>
  </spatial>

  <spatial name="tendon_east_1" width="0.002" rgba="0.1 0.1 0.9 1">
