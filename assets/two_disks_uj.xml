<mujoco model="official_elastic_rod_cable_upright">
<size      
  nstack="20000000"    
  nconmax="8000"      
  njmax="300000"      
/>

  <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>
  <option timestep="0.002" gravity="0 0 -9.8" integrator="implicitfast" />

  <!-- 启用 MuJoCo 官方弹性 “cable” 插件 -->
  <extension>
    <plugin plugin="mujoco.elasticity.cable"/>
  </extension>

  <asset>
    <texture name="texplane" type="2d" builtin="checker"
             width="512" height="512" rgb1="0.2 0.4 0.8" rgb2="1 1 1" mark="none"/>
    <material name="ground" texture="texplane" texrepeat="4 4" reflectance="0.2"/>
  </asset>

  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="3 3 0.1"
          material="ground" contype="1" conaffinity="1"
          friction="1 0.005 0.0001"/>
    <body name="target_body" pos="0 0 0" mocap="true">
    <geom type="sphere" size="0.015" rgba="0 1 0 0.5" contype="0" conaffinity="0"/>
    </body>
    <!-- <body name="white_backdrop" pos="0 -0.5 1.0">
        <geom type="box" size="2 0.01 2" rgba="1 1 1 1" 
              contype="0" conaffinity="0"/>
    </body> -->
    <!-- 竖直的弹性杆：将原本沿 x 的 cable 通过父 body 旋转到 z 方向 -->
    <body name="rod_base" pos="0 0 1.3"> <!-- 略抬起 1 cm，避免与地面接触穿插 -->
      <site name="base_north"  pos="0 0.08 0.00" size="0.001" rgba="0 1 0 1"/>
      <site name="base_south" pos="0.0 -0.08 0.00" size="0.001" rgba="0 1 0 1"/>
      <site name="base_west" pos="-0.08 0 0.00" size="0.001" rgba="0 1 0 1"/>
      <site name="base_east" pos="0.08 0 0.00" size="0.001" rgba="0 1 0 1"/>
      <site name="base_first" pos="0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="base_second" pos="-0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="base_third" pos="-0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="base_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <!-- 绕 y 轴 +90°：x 轴 -> z 轴 -->
      <body name="rod_upright"  quat="0 1 0 0">
        <composite prefix="rod" type="cable"
                   curve="0 0 s"             
                   count="81 1 1"          
                   size="1 0 0"          
                   offset="0 0 0"           
                   initial="fixed">

          <!-- 物理参数：弯曲与扭转刚度 -->
          <plugin plugin="mujoco.elasticity.cable">
            <config key="twist" value="{twist_val}"/>
            <config key="bend"  value="{bend_val}"/>
            <!-- vmax 可设 0 表示不限制；这里给一个适中的限制以保持数值稳定 -->
            <config key="vmax"  value="0"/>
          </plugin>

          <!-- 每段主关节的阻尼与等效转动惯量（稳定性） -->
          <joint kind="main" damping="{damping_val}" armature="0.05"/>

          <!-- 线缆段的可视几何（胶囊半径约 7.5 mm） -->
          <geom type="capsule" size="0.002" rgba="0.8 0.2 0.1 1"/>
          
        </composite>
      </body>

      <!-- 可视化底端位置的小标记（非必须） -->
      <site name="rod_root" pos="0 0 1.3" size="0.001" rgba="0.1 0.5 0.9 1"/>
    </body>

    <body name="ring_1_body" pos="0 0 1.2">
    <joint type="free"/>
      <geom name="ring_1" type="cylinder" size="0.1 0.004"
            density="50" rgba="0.2 0.2 0.2 0.5" contype="1" conaffinity="1"/>
      <site name="ring1_north"  pos="0 0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring1_south"  pos="0 -0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring1_east"  pos="0.08 0.0 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring1_west"  pos="-0.08 0 0" size="0.003" rgba="1 0 0 1"/>
      <site name="ring1_first" pos="0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring1_second" pos="-0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring1_third" pos="-0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring1_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
    </body>

    <body name="ring_2_body" pos="0 0 1.1">
    <joint type="free"/>
      <geom name="ring_2" type="cylinder" size="0.1 0.004"
