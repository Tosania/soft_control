      <site name="ring3_north"  pos="0 0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring3_south"  pos="0 -0.08 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring3_east"  pos="0.08 0.0 0.00" size="0.003" rgba="1 0 0 1"/>
      <site name="ring3_west"  pos="-0.08 0 0" size="0.003" rgba="1 0 0 1"/>
      <site name="ring3_first" pos="0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring3_second" pos="-0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring3_third" pos="-0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring3_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
    </body>

    <body name="ring_4_body" pos="0 0 0.9">
    <joint type="free"/>
      <geom name="ring_4" type="cylinder" size="0.1 0.004"
