      <site name="ring4_third" pos="-0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring4_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
    </body>

    <body name="ring_5_body" pos="0 0 0.8">
