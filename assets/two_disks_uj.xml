      <site name="ring5_west"  pos="-0.08 0 0" size="0.003" rgba="1 0 0 1"/>
      <site name="ring5_first" pos="0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring5_second" pos="-0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring5_third" pos="-0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
      <site name="ring5_fourth" pos="0.0566 -0.0566 0" size="0.001" rgba="0 1 0 1"/>
    </body>

    <body name="ring_6_body" pos="0 0 0.7">
    <joint type="free"/>
      <geom name="ring_6" type="cylinder" size="0.1 0.004"
