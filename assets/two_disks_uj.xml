      <geom name="ring_10" type="cylinder" size="0.1 0.004"
            density="50" rgba="0.2 0.2 0.2 0.5" contype="1" conaffinity="1"/>
      
      <site name="ring10_first" pos="0.0566 0.0566 0" size="0.001" rgba="0 1 0 1"/>
